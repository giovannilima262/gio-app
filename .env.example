# DATABASE_URL=

# ── Auth (add when auth provider is chosen) ──────────────────────────────────
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# ── Third-party services ─────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
