# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file with real secrets.
# Set these variables in Vercel (web) and Railway (api) dashboards for production.

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Google / Gmail ────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Google Cloud Pub/Sub topic for Gmail push notifications
# Format: projects/{project-id}/topics/{topic-name}
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# URL of the deployed API (used by web to call API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Allowed CORS origins for the API
CORS_ORIGIN=http://localhost:3000
